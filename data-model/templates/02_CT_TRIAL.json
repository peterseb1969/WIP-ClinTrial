{
  "value": "CT_TRIAL",
  "label": "Clinical Trial",
  "description": "Core clinical trial record with protocol information, status, and study design",
  "namespace": "clintrial",
  "identity_fields": ["nct_id"],
  "fields": [
    {"name": "nct_id", "label": "NCT ID", "type": "string", "mandatory": true, "pattern": "^NCT\\d{8,11}$"},
    {"name": "title", "label": "Official Title", "type": "string", "mandatory": true},
    {"name": "brief_title", "label": "Brief Title", "type": "string", "mandatory": false},
    {"name": "acronym", "label": "Acronym", "type": "string", "mandatory": false},
    {"name": "status", "label": "Status", "type": "term", "mandatory": true, "terminology_ref": "CT_STATUS"},
    {"name": "phases", "label": "Phases", "type": "array", "mandatory": false, "items": {"type": "term", "terminology_ref": "CT_PHASE"}},
    {"name": "study_type", "label": "Study Type", "type": "term", "mandatory": true, "terminology_ref": "CT_STUDY_TYPE"},
    {"name": "therapeutic_areas", "label": "Therapeutic Areas", "type": "array", "mandatory": false, "items": {"type": "term", "terminology_ref": "CT_THERAPEUTIC_AREA"}},
    {"name": "brief_summary", "label": "Brief Summary", "type": "string", "mandatory": false},
    {"name": "detailed_description", "label": "Detailed Description", "type": "string", "mandatory": false},
    {"name": "enrollment", "label": "Enrollment", "type": "integer", "mandatory": false},
    {"name": "start_date", "label": "Start Date", "type": "date", "mandatory": false},
    {"name": "primary_completion_date", "label": "Primary Completion Date", "type": "date", "mandatory": false},
    {"name": "completion_date", "label": "Completion Date", "type": "date", "mandatory": false},
    {"name": "sponsor", "label": "Sponsor", "type": "reference", "mandatory": true, "reference_template": "CT_ORGANIZATION", "reference_type": "document"},
    {"name": "collaborators", "label": "Collaborators", "type": "array", "mandatory": false, "items": {"type": "string"}},
    {"name": "interventions", "label": "Interventions", "type": "array", "mandatory": false, "items": {"type": "term", "terminology_ref": "CT_MOLECULE"}},
    {"name": "conditions", "label": "Conditions", "type": "array", "mandatory": false, "items": {"type": "string"}},
    {"name": "eligibility_criteria", "label": "Eligibility Criteria", "type": "string", "mandatory": false},
    {"name": "minimum_age", "label": "Minimum Age", "type": "string", "mandatory": false},
    {"name": "maximum_age", "label": "Maximum Age", "type": "string", "mandatory": false},
    {"name": "sex", "label": "Sex", "type": "string", "mandatory": false},
    {"name": "healthy_volunteers", "label": "Healthy Volunteers", "type": "string", "mandatory": false},
    {"name": "has_results", "label": "Has Results", "type": "boolean", "mandatory": false},
    {"name": "ctgov_url", "label": "ClinicalTrials.gov URL", "type": "string", "mandatory": false, "semantic_type": "url"},
    {"name": "documents", "label": "Documents", "type": "file", "mandatory": false, "file_config": {"accept": "application/pdf", "multiple": true, "max_count": 20, "max_size_mb": 50}}
  ],
  "reporting": {"sync_enabled": true, "sync_strategy": "latest_only"}
}
