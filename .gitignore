# Sync state — machine-specific, regenerated by import script
data-model/sync-state.json

# Raw CT.gov API responses — large, regenerable via --save-raw
data/raw/

# MCP config — contains local paths and dev API keys
.mcp.json

# kb client config — contains a machine-specific key-file path + internal URL
.claude/kb.json

# CLAUDE.md regeneration sidecar — transient review artifact from --refresh
CLAUDE.md.refresh

# Root-level gene-pool lib tarballs — reference drops from --refresh; the app's
# real pins live in clintrial-explorer/libs/ (CASE-442 single source of truth).
# Repo-root libs/ tracks only the READMEs and the wip-toolkit wheel.
libs/*.tgz

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node.js (Phase 4)
node_modules/
dist/
*.tsbuildinfo
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code ephemera
.claude-context-pct

# Import run logs (local only)
import-log-*.txt

# Raw CT.gov dumps used during import debugging
clintrial-raw/

# Cross-agent case store (symlinked to shared directory)
yac-discussions

# Session identity — minted per session by /wip-setup//wip-wake, never committed
.claude/.session-id

# Local session reports (per-session working memory; KB-mirrored, not committed)
reports/
